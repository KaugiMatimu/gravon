rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read access for both collections so users can browse listings.
    // Adjust individual write rules to restrict modifications to owners/admins.

    match /properties/{propertyId} {
      allow read: if true; // everyone can view properties
      allow create, update, delete: if request.auth != null
                                 && request.auth.uid == request.resource.data.landlordId;
    }

    match /cars/{carId} {
      allow read: if true; // everyone can view cars
      allow create, update, delete: if request.auth != null
                                 && request.auth.uid == request.resource.data.ownerId;
    }

    // other documents remain locked unless new rules are added
    match /{document=**} {
      allow read, write: if false;
    }
  }
}